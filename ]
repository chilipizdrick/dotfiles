{
  pkgs,
  config,
  lib,
  ...
}:
with lib; let
  cfg = config.games;
in {
  options.games = {
    enable = mkEnableOption "game related stuff";
    steam = mkEnableOption "steam";
    gamescopeScreenProfile = mkOption {
      type = types.list;
      default = [
        "-W 2560"
        "-H 1600"
        "-r 120"
      ];
      example = [
        "-W 1920"
        "-H 1080"
        "-r 60"
      ];
      description = "Gamescope output screen profile to use";
    };
  };

  config = mkIf cfg.enable {
    programs = {
      steam = {
        enable = mkIf cfg.steam true;
        gamescopeSession.enable = true;
      };
      gamescope = {
        enable = mkIf cfg.steam true;
        capSysNice = true;
        args =
          [
            "-f"
            "-S integer"
            "--rt"
            "--adaptive-sync"
            "--expose-wayland"
            "--mangoapp"
          ]
          ++ cfg.gamescopeScreenProfile;
      };
      gamemode = {
        enable = true;
      };
    };

    environment.systemPackages = with pkgs; let
      steamPkgs = [
        # mangohud
      ];
    in
      (optionals cfg.steam steamPkgs) ++ [];
  };
}
