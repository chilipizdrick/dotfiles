{
  "layer": "top",
  "position": "top",
  "margin-top": 5,
  "margin-bottom": 0,
  "margin-left": 5,
  "margin-right": 5,
  "height": 0,
  "spacing": 0,
  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces",
    "mpris"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "tray",
    "backlight",
    "pulseaudio",
    "custom/vpn",
    "network",
    "battery",
    "custom/powermenu"
  ],
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 25,
    "icon-theme": "Default",
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": [
      "Alacritty"
    ]
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"]
  },
  "memory": {
    "interval": 5,
    "format": " ΎΙΑ  {usage}% ",
    "max-length": 10
  },
  "cpu": {
    "interval": 5,
    "format": " ΎΘ╛  {usage}% ",
    "max-length": 10
  },
  "tray": {
    "spacing": 10,
    "show-passive-items": true
  },
  "clock": {
    "tooltip-format": "<tt>{calendar}</tt>",
    "format": "ΎΕ│ {:%a %d %b ΎΑΩ %H:%M}",
  },
  "network": {
    "format-wifi": "{icon} {essid}",
    "format-disconnected": "Disconnected έγι ",
    "format-icons": [
      "≤░νψ ",
      "≤░νθ ",
      "≤░νλ ",
      "≤░νξ ",
      "≤░νρ "
    ],
    "tooltip-format-disconnected": "Disconnected",
    "tooltip-format-wifi": "{icon} {essid}\nέΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
    //"on-click": "~/.config/waybar/rofi-wifi-menu.sh",
    "format-ethernet": "{ifname}",
    "tooltip-format-ethernet": "≤░ΑΓ  {ifname}\nέΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
    "nospacing": 1,
    "interval": 5
  },
  "pulseaudio": {
    "format": "{icon}{volume}%",
    "format-bluetooth": "≤░Γ░ {volume}%",
    "nospacing": 1,
    "tooltip-format": "Volume : {volume}%",
    "format-muted": "≤░ζθ ",
    "format-icons": {
      "headphone": "ΎΑξ ",
      "default": [
        "≤░Χ┐ ",
        "≤░ΨΑ ",
        "≤░Χ╛ "
      ]
    },
    "on-click": "pavucontrol",
    "scroll-step": 1
  },
  "custom/launcher": {
    "format": "ΎΝΥ",
    "tooltip": false,
    "on-click": "rofi -terminal ${terminal} -show drun -modes drun"
  },
  "battery": {
    "format": "{icon} {capacity}%",
    "format-icons": {
      "charging": [
        "≤░λε",
        "≤░ΓΗ",
        "≤░ΓΘ",
        "≤░ΓΙ",
        "≤░λζ",
        "≤░ΓΚ",
        "≤░λη",
        "≤░ΓΛ",
        "≤░ΓΜ",
        "≤░ΓΖ"
      ],
      "default": [
        "≤░Β║",
        "≤░Β╗",
        "≤░Β╝",
        "≤░Β╜",
        "≤░Β╛",
        "≤░Β┐",
        "≤░ΓΑ",
        "≤░ΓΒ",
        "≤░ΓΓ",
        "≤░Β╣"
      ]
    },
    "interval": 5,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "tooltip": true
  },
  "custom/powermenu": {
    "format": "έΠ╗",
    "tooltip": false,
    "on-click": "wlogout -b 5"
  },
  "mpris": {
    "format": "{player_icon} {dynamic}",
    "format-paused": "{status_icon} {dynamic}",
    "player-icons": {
      "spotify": "ΎΗ╝ ",
      "default": "έΨ╢"
    },
    "dynamic-order": ["title", "artist", "position", "length"],
    "dynamic-len": 50,
    "interval": 1,
    "status-icons": {
      // "paused": "έΠ╕"
      "paused": "||"
    },
    "ignored-players": [ "firefox", "chromium" ]
  },
  "custom/vpn": {
    "exec": "~/.config/waybar/query-wireguard-vpn.sh",
    "interval": 5,
    "format": "VPN",
    // "tooltip-format": "{tooltip}",
    "on-click": "~/.config/waybar/toggle-wireguard-vpn.sh",
  }
}
