{
  "layer": "top",
  "position": "top",
  "margin-top": 5,
  "margin-bottom": 0,
  "margin-left": 5,
  "margin-right": 5,
  "height": 0,
  "spacing": 0,
  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces",
    "mpris"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "tray",
    "backlight",
    "pulseaudio",
    "custom/vpn",
    "network",
    "battery",
    "custom/powermenu"
  ],
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 25,
    "icon-theme": "Default",
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": [
      "Alacritty"
    ]
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["оОН", "оПУ", "оПС", "оПП", "оПО", "оПН", "оПК", "оПИ", "оОЫ"]
  },
  "memory": {
    "interval": 5,
    "format": " пИА  {usage}% ",
    "max-length": 10
  },
  "cpu": {
    "interval": 5,
    "format": " пЗЊ  {usage}% ",
    "max-length": 10
  },
  "tray": {
    "spacing": 10,
    "show-passive-items": true
  },
  "clock": {
    "tooltip-format": "<tt>{calendar}</tt>",
    "format": "{:%H:%M  %a %d %b}",
  },
  "network": {
    "format-wifi": "{icon} {essid}",
    "format-disconnected": "Disconnected вЪ† ",
    "format-icons": [
      "у∞§ѓ ",
      "у∞§Я ",
      "у∞§Ґ ",
      "у∞§• ",
      "у∞§® "
    ],
    "tooltip-format-disconnected": "Disconnected",
    "tooltip-format-wifi": "{icon} {essid}\nвЗ£{bandwidthDownBytes}  вЗ°{bandwidthUpBytes}",
    //"on-click": "~/.config/waybar/rofi-wifi-menu.sh",
    "format-ethernet": "{ifname}",
    "tooltip-format-ethernet": "у∞АВ  {ifname}\nвЗ£{bandwidthDownBytes}  вЗ°{bandwidthUpBytes}",
    "nospacing": 1,
    "interval": 5
  },
  "pulseaudio": {
    "format": "{icon}{volume}%",
    "format-bluetooth": "у∞В∞ {volume}%",
    "nospacing": 1,
    "tooltip-format": "Volume : {volume}%",
    "format-muted": "у∞ЭЯ ",
    "format-icons": {
      "headphone": "пА• ",
      "default": [
        "у∞Хњ ",
        "у∞ЦА ",
        "у∞ХЊ "
      ]
    },
    "on-click": "pavucontrol",
    "scroll-step": 1
  },
  "custom/launcher": {
    "format": "пМУ",
    "tooltip": false,
    "on-click": "rofi -terminal ${terminal} -show drun -modes drun"
  },
  "battery": {
    "format": "{icon} {capacity}%",
    "format-icons": {
      "charging": [
        "у∞ҐЬ",
        "у∞ВЖ",
        "у∞ВЗ",
        "у∞ВИ",
        "у∞ҐЭ",
        "у∞ВЙ",
        "у∞ҐЮ",
        "у∞ВК",
        "у∞ВЛ",
        "у∞ВЕ"
      ],
      "default": [
        "у∞БЇ",
        "у∞Бї",
        "у∞БЉ",
        "у∞Бљ",
        "у∞БЊ",
        "у∞Бњ",
        "у∞ВА",
        "у∞ВБ",
        "у∞ВВ",
        "у∞Бє"
      ]
    },
    "interval": 5,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "tooltip": true
  },
  "custom/powermenu": {
    "format": "вПї",
    "tooltip": false,
    "on-click": "wlogout -b 5"
  },
  "mpris": {
    "format": "{player_icon} {dynamic}",
    "format-paused": "{status_icon} {dynamic}",
    "player-icons": {
      "spotify": "пЖЉ ",
      "default": "вЦґ"
    },
    "dynamic-order": ["title", "artist", "position", "length"],
    "dynamic-len": 50,
    "interval": 1,
    "status-icons": {
      // "paused": "вПЄ"
      "paused": "||"
    },
    "ignored-players": [ "firefox", "chromium" ]
  },
  "custom/vpn": {
    "exec": "~/.config/waybar/query-wireguard-vpn.sh",
    "interval": 1,
    "format": "VPN",
    // "tooltip-format": "{tooltip}",
    "on-click": "~/.config/waybar/toggle-wireguard-vpn.sh",
  }
}
